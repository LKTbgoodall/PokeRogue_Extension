{
  "manifest_version": 3,
  "name": "PokeRogue Overlay Calc",
  "version": "2.0",
  "permissions": ["activeTab", "scripting", "tabs", "alarms"],
  "host_permissions": ["https://pokerogue.net/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://pokerogue.net/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["icons/*.svg"],
      "matches": ["https://pokerogue.net/*"]
    }
  ]
}